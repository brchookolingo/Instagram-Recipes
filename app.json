{
  "expo": {
    "name": "ReciGrams",
    "slug": "ReciGrams",
    "version": "1.0.0",
    "scheme": "instagramrecipes",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bchookolingo.InstagramRecipes",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.bchookolingo.InstagramRecipes"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "extra": {
      "eas": {
        "projectId": "7098a2e4-b1cf-46a8-bd93-a98500daa298"
      }
    },
    "owner": "bchookolingo",
    "plugins": [
      "expo-secure-store"
    ]
  }
}
